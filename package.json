{
  "name": "@transformers-js/transformers-js",
  "version": "0.1.0",
  "type": "module",
  "description": "WebGPU-primary transformer inference runtime for the browser",
  "exports": {
    ".": {
      "browser": "./dist/transformers.web.js",
      "node": "./dist/transformers.node.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --noEmit && node scripts/build.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "vitest --reporter=verbose",
    "sync": "tsx codegen/sync.ts",
    "sync:init": "tsx codegen/sync.ts --init",
    "benchmark": "tsx benchmark/compare.ts",
    "benchmark:build": "node scripts/build-benchmark.js",
    "benchmark:serve": "node scripts/build-benchmark.js && python3 -m http.server 3000 --directory benchmark"
  },
  "dependencies": {
    "@huggingface/tokenizers": "^0.1.3",
    "onnxruntime-node": "^1.24.3",
    "onnxruntime-web": "^1.20.1"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@types/node": "^22.0.0",
    "@webgpu/types": "^0.1.69",
    "esbuild": "^0.25.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "zod": "^4.3.6"
  }
}
